// ─── Procesos Automáticos ───────────────────────────────────

enum ProcessRunStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}

enum ProcessTriggerType {
  MANUAL
  CRON
  WEBHOOK
  SYSTEM
}

model ProcessRun {
  id          String             @id @default(cuid())
  processSlug String
  status      ProcessRunStatus   @default(PENDING)
  triggerType ProcessTriggerType @default(MANUAL)
  triggeredBy String?
  startedAt   DateTime           @default(now())
  finishedAt  DateTime?
  durationMs  Int?
  output      Json?
  error       String?
  phases      Json?
  metadata    Json?

  @@index([processSlug, startedAt(sort: Desc)])
  @@index([status])
  @@map("process_runs")
}

// ─── GastroLab: Analytics de Comensales ─────────────────────────

model CoverSnapshot {
  id                   String   @id @default(cuid())
  restaurantLocationId String
  date                 DateTime @db.Date
  totalCovers          Int      @default(0)        // Comensales totales del día
  totalReservations    Int      @default(0)        // Número de reservas
  avgPartySize         Float    @default(0)        // Media comensales por reserva
  maxPartySize         Int      @default(0)        // Máximo en una sola reserva
  coversByStatus       Json?                        // { "confirmed": 45, "cancelled": 5 }
  coversByHour         Json?                        // { "13:00": 22, "21:00": 35 }
  lunchCovers          Int?                         // Comensales servicio comida
  dinnerCovers         Int?                         // Comensales servicio cena
  walkInCovers         Int?                         // Walk-ins (sin reserva)
  syncedAt             DateTime @default(now())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  restaurantLocation   RestaurantLocation @relation(fields: [restaurantLocationId], references: [id])

  @@unique([restaurantLocationId, date])
  @@index([date])
  @@index([restaurantLocationId, date])
  @@map("cover_snapshots")
}

model CoverSyncLog {
  id                   String    @id @default(cuid())
  restaurantLocationId String?
  status               String    @default("RUNNING") // RUNNING | SUCCESS | FAILED
  dateRangeStart       DateTime
  dateRangeEnd         DateTime
  snapshotsCreated     Int       @default(0)
  snapshotsUpdated     Int       @default(0)
  errors               Json?
  durationMs           Int?
  startedAt            DateTime  @default(now())
  finishedAt           DateTime?

  @@index([status])
  @@index([startedAt(sort: Desc)])
  @@map("cover_sync_logs")
}

model AiToneProfile {
  id        String   @id @default(cuid())
  name      String   @default("default")
  toneGuide String   @db.Text
  examples  Json     @default("[]")
  isActive  Boolean  @default(true)
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_tone_profiles")
}

// ─── Ágora TPV ─────────────────────────────────────────────────

model AgoraSalesSnapshot {
  id                   String   @id @default(cuid())
  restaurantLocationId String
  businessDay          DateTime @db.Date

  // Métricas de facturación
  totalInvoices        Int      @default(0)
  totalGrossAmount     Float    @default(0)
  totalNetAmount       Float    @default(0)
  totalAmount          Float    @default(0)
  totalGuests          Int      @default(0)
  avgTicket            Float    @default(0)
  avgSpendPerGuest     Float    @default(0)

  // Desgloses JSON
  salesByFamily        Json?
  salesByPaymentMethod Json?
  salesByHour          Json?
  topProducts          Json?
  taxBreakdown         Json?

  // Cierre de caja
  cashExpected         Float?
  cashReal             Float?
  cashDifference       Float?

  syncedAt             DateTime @default(now())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  restaurantLocation   RestaurantLocation @relation(fields: [restaurantLocationId], references: [id])

  @@unique([restaurantLocationId, businessDay])
  @@index([businessDay])
  @@index([restaurantLocationId, businessDay])
  @@map("agora_sales_snapshots")
}

model FoodCostSnapshot {
  id                   String   @id @default(cuid())
  restaurantLocationId String
  periodStart          DateTime @db.Date
  periodEnd            DateTime @db.Date

  // Coste Real (de GStock costReals)
  realCostTotal        Float    @default(0)
  realCostByCategory   Json?    // [{ name, amount }]

  // Coste Teórico (de GStock costTheoreticals)
  theoreticalCostTotal Float    @default(0)

  // Variación calculada
  variance             Float    @default(0)   // real - teórico
  variancePercent      Float    @default(0)   // ((real-teórico)/teórico)*100

  // Revenue del periodo (de AgoraSalesSnapshot)
  periodRevenue        Float?
  foodCostPercent      Float?   // (realCostTotal / periodRevenue) * 100

  // Stock variation (de GStock stockVariations)
  stockVariationTotal  Float?

  syncedAt             DateTime @default(now())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  restaurantLocation   RestaurantLocation @relation(fields: [restaurantLocationId], references: [id])

  @@unique([restaurantLocationId, periodStart, periodEnd])
  @@index([restaurantLocationId, periodStart])
  @@map("food_cost_snapshots")
}

model AgoraProduct {
  id         String   @id @default(cuid())
  agoraId    Int      @unique
  name       String
  familyId   Int?
  familyName String?
  vatRate    Float?
  mainPrice  Float?
  costPrice  Float?
  barcode    String?
  isActive   Boolean  @default(true)

  recipeId   String?
  recipe     Recipe?  @relation(fields: [recipeId], references: [id])

  syncedAt   DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([name])
  @@index([familyName])
  @@index([recipeId])
  @@map("agora_products")
}

model AgoraSyncLog {
  id               String    @id @default(cuid())
  syncType         String
  status           String    @default("RUNNING")
  dateRangeStart   DateTime?
  dateRangeEnd     DateTime?
  snapshotsCreated Int       @default(0)
  snapshotsUpdated Int       @default(0)
  productsCreated  Int       @default(0)
  productsUpdated  Int       @default(0)
  errors           Json?
  durationMs       Int?
  startedAt        DateTime  @default(now())
  finishedAt       DateTime?

  @@index([status])
  @@index([startedAt(sort: Desc)])
  @@map("agora_sync_logs")
}
